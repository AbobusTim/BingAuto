APP_MODE=telegram
LOG_LEVEL=INFO
DRY_RUN=true
RUNTIME_SETTINGS_PATH=runtime\trading_settings.json
ALERT_STATS_PATH=runtime\alert_stats.json
TRADE_HISTORY_PATH=runtime\trade_history.json

BINGX_API_KEY=
BINGX_SECRET_KEY=
BINGX_BASE_URL=https://open-api.bingx.com
BINGX_CATEGORY=linear
BINGX_POLL_INTERVAL_SEC=3
BINGX_SIGNAL_THRESHOLD=0.003
BINGX_SIGNAL_COOLDOWN_SEC=120
BINGX_DUPLICATE_TTL_SEC=900
BINGX_MAX_CONCURRENT_REQUESTS=20

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=bingx_signal_listener
TELEGRAM_CHANNEL=@your_channel
TELEGRAM_SIGNAL_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_SESSION=bingx_admin_bot
TELEGRAM_ADMIN_IDS=
RUN_CONTROL_BOT=true
RUN_EXECUTION_ENGINE=true
RUN_PARSER_SOURCE=false
RUN_TELEGRAM_SOURCE=true
